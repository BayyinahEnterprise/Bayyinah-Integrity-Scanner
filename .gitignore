# -----------------------------------------------------------------------------
# Bayyinah .gitignore
# -----------------------------------------------------------------------------
#
# What stays tracked, what stays out. Keep this list conservative, only
# tooling byproducts and OS cruft. Source, fixtures, CI config, docs, and
# the reference modules under legacy/ all stay in the tree.
# -----------------------------------------------------------------------------

# --- Python bytecode + import caches ----------------------------------------
__pycache__/
*.py[cod]
*$py.class

# --- Build / distribution / packaging ---------------------------------------
build/
dist/
*.egg
*.egg-info/
.eggs/
wheels/
pip-wheel-metadata/
MANIFEST
sdist/

# --- Installer + virtualenv -------------------------------------------------
.venv/
venv/
env/
ENV/
.python-version

# --- Testing + coverage -----------------------------------------------------
.pytest_cache/
.cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/
.nox/
nosetests.xml
*.cover
*.py,cover

# --- Type-checker / linter caches -------------------------------------------
.mypy_cache/
.ruff_cache/
.pyre/
.pytype/
.dmypy.json
dmypy.json

# --- Editor / IDE scratch ---------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*.swn
*~
.*.sw?

# --- OS cruft ---------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# --- Jupyter / IPython ------------------------------------------------------
.ipynb_checkpoints/
profile_default/
ipython_config.py

# --- Local scratch / secrets (never ship) -----------------------------------
.env
.env.*
!.env.example
*.local
scratch/
tmp/

# --- Bayyinah-specific: regenerated fixtures aren't kept in git -------------
# Fixtures are produced deterministically by tests/make_test_documents.py
# on every CI run. Keeping them out of the tree prevents drift between the
# checked-in bytes and the generator. (If you need to inspect a fixture,
# regenerate it locally.)
#
# If this policy ever changes, remove the lines below.
# tests/fixtures/**/*.pdf
# tests/fixtures/**/*.docx
# tests/fixtures/**/*.xlsx
# tests/fixtures/**/*.pptx
# tests/fixtures/**/*.eml

# --- Built docs (if/when docs/ is added) ------------------------------------
docs/_build/
site/
docs/benchmarks/clean_50pg.pdf
